# Copy this file to .env and fill in your values
# .env is git-ignored and must never be committed

# OpenAI API Key — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs TTS — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=7oj6OS5ga3IxvikkhBn1

# MongoDB Atlas connection string — https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=AppName

# Shelly smart plug IP on your local network
SHELLY_IP=192.168.0.1

# Local paths used by action handlers (Windows-style paths OK on Windows)
ATTACHMENT_FOLDER_PATH=C:/Users/YourName/Desktop/Attachments
BLUESTACKS_EXE_PATH=C:/Program Files (x86)/BlueStacks X/BlueStacks X.exe
